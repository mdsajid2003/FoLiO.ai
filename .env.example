# ── Firebase client (Vite — safe to expose to browser) ───────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_RAZORPAY_KEY_ID=

# ── Server-only secrets (never expose to client) ─────────────────────────────
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
ANTHROPIC_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
GEMINI_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# Override default KA seller state for all users (2-letter state code)
SELLER_REGISTERED_STATE=KA

# ── Production ────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://yourdomain.com
PORT=3000
NODE_ENV=production
